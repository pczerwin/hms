# ==========================================
target/
build/
out/
*.class
*.war
*.ear

# ==========================================
# MAVEN
# ==========================================
.mvn/wrapper/maven-wrapper.jar
.m2/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.asc
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

