
spring:
  config:
    activate:
      on-profile: dev

  # -----------------------------
  # Datasource (local MySQL)
  # Copy this file to application-dev.yml and fill in your local credentials.
  # application-dev.yml is gitignored and must never be committed.
  # -----------------------------
  datasource:
    url: >
      jdbc:mysql://localhost:3306/hygiene_app
      ?useSSL=false
      &serverTimezone=UTC
      &useUnicode=true
      &characterEncoding=UTF-8
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver

  # -----------------------------
  # JPA / Hibernate (dev visibility)
  # -----------------------------
  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        connection:
          characterEncoding: UTF-8
          CharSet: UTF-8
          useUnicode: true

# -------------------------------------------------
# Logging (developer-friendly)
# -------------------------------------------------
logging:
  level:
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql: TRACE

